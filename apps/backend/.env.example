# ============================================================
# 로컬 개발용 .env 예시 — 프로덕션은 AWS Secrets Manager 사용
# ============================================================

NODE_ENV=development

# 서버 설정
PORT=4000

# 데이터베이스
# 로컬: localhost / AWS: RDS 엔드포인트 (e.g. xxx.ap-northeast-2.rds.amazonaws.com)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_DATABASE=reservation_db

# IMAP 이메일 설정
# Gmail 사용 시: Google 계정 > 보안 > 앱 비밀번호 생성
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your@gmail.com
IMAP_PASSWORD=앱_비밀번호_16자리

# AWS Bedrock AI
# ECS에서는 Task Role IAM 권한으로 자동 인증 (아래 키 불필요)
# 로컬 개발 시에는 ~/.aws/credentials 또는 아래 환경변수 사용
AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=     # 로컬 전용, ECS에서는 사용 안 함
# AWS_SECRET_ACCESS_KEY= # 로컬 전용, ECS에서는 사용 안 함

# JWT 인증
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# 관리자 계정 (초기 설정용)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234
